# Production Environment Configuration
VITE_API_BASE_URL=/api
VITE_APP_TITLE=PaiNaiDee - Discover Thailand's Hidden Gems
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=production

# Feature Flags for Production
